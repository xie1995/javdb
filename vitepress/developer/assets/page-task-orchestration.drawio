        <mxCell id="ap3" value="锚点优化初始化&#xa;anchorOptimization:init" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=14;" vertex="1" parent="ag2"><mxGeometry x="30" y="300" width="280" height="90" as="geometry"/></mxCell>
        <mxCell id="ap4" value="列表增强复用能力&#xa;页面卡片交互增强" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=14;" vertex="1" parent="ag2"><mxGeometry x="30" y="420" width="280" height="90" as="geometry"/></mxCell>
