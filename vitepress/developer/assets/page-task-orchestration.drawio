    <diagram id="list-page-flow" name="列表页 - 任务执行与调度（树状）">
    <mxGraphModel dx="2200" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="lt0" value="列表页入口&#xa;非 /v/* 且非 /actors/*&#xa;页面初始化开始&#xa;包含：列表观察、增强初始化、并行旁路任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;fontStyle=1;fontSize=16;" vertex="1" parent="1"><mxGeometry x="990" y="50" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="lt1" value="list:observe:init&#xa;功能点：列表观察器初始化与首轮处理&#xa;critical / background_allowed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#f87171;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="220" width="400" height="90" as="geometry"/></mxCell>
        <mxCell id="lt2" value="listEnhancement:init&#xa;功能点：列表增强初始化&#xa;high / priority=7 / background_allowed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="380" width="400" height="90" as="geometry"/></mxCell>
