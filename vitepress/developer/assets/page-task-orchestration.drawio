    <diagram id="actor-page-flow" name="演员页 - 任务执行与调度（树状）">
    <mxGraphModel dx="2200" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="at0" value="演员页入口&#xa;/actors/*&#xa;页面初始化开始&#xa;包含：演员增强、演员备注、全局清理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;fontStyle=1;fontSize=16;" vertex="1" parent="1"><mxGeometry x="990" y="50" width="380" height="100" as="geometry"/></mxCell>
        <mxCell id="at1" value="actorEnhancement:init&#xa;功能点：演员页增强初始化&#xa;critical / background_allowed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#f87171;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="210" width="400" height="90" as="geometry"/></mxCell>
        <mxCell id="at2" value="actorEnhancement:actionButtons&#xa;功能点：演员页操作按钮注入&#xa;critical / priority=9 / background_allowed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#f87171;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="360" width="400" height="90" as="geometry"/></mxCell>
        <mxCell id="at3" value="actorRemarks:actorPage&#xa;功能点：演员页备注批量加载&#xa;idle / timeout=actorRemarksTaskTimeoutMs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="520" width="400" height="90" as="geometry"/></mxCell>
        <mxCell id="at4" value="ui:remove-unwanted&#xa;功能点：移除无关按钮&#xa;high / priority=3 / background_allowed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="690" width="400" height="90" as="geometry"/></mxCell>
        <mxCell id="at5" value="演员页主链收尾&#xa;目标：操作按钮与备注能力已落地" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#8b5cf6;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="860" width="400" height="90" as="geometry"/></mxCell>

