        <mxCell id="ab2" value="时间分段 divider&#xa;功能点：按月份插入分隔线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="ag1"><mxGeometry x="330" y="70" width="240" height="84" as="geometry"/></mxCell>
        <mxCell id="ab3" value="列表项状态处理&#xa;功能点：标签 / 收藏 / 黑名单控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="ag1"><mxGeometry x="610" y="70" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="ab4" value="扫描新作品按钮能力&#xa;功能点：演员页新作品扫描入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="ag1"><mxGeometry x="900" y="70" width="280" height="84" as="geometry"/></mxCell>

        <mxCell id="ag2" value="演员页并行旁路任务组" style="swimlane;rounded=1;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="210" width="340" height="760" as="geometry"/></mxCell>
