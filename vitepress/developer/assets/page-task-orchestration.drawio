        <mxCell id="lt4" value="列表页主链收尾&#xa;目标：观察器已接管、首轮增强已生效、可继续处理新增卡片" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#8b5cf6;fontSize=15;" vertex="1" parent="1"><mxGeometry x="980" y="1460" width="400" height="90" as="geometry"/></mxCell>

        <mxCell id="lr1" value="主链" style="text;html=1;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1160" y="15" width="60" height="30" as="geometry"/></mxCell>

        <mxCell id="lg1" value="listEnhancement:init 功能组" style="swimlane;rounded=1;html=1;fillColor=#fffbeb;strokeColor=#f59e0b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="430" y="720" width="1510" height="250" as="geometry"/></mxCell>
        <mxCell id="lb1" value="滚动翻页接管&#xa;功能点：列表持续加载能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="lg1"><mxGeometry x="40" y="70" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="lb2" value="演员过滤准备&#xa;功能点：黑名单 / 非收藏 / 未识别控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="lg1"><mxGeometry x="330" y="70" width="260" height="84" as="geometry"/></mxCell>
        <mxCell id="lb3" value="列表显示控制&#xa;功能点：列数 / 宽度 / 容器扩展" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="lg1"><mxGeometry x="630" y="70" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="lb4" value="状态角标增强&#xa;功能点：卡片状态标签渲染" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="lg1"><mxGeometry x="920" y="70" width="250" height="84" as="geometry"/></mxCell>
        <mxCell id="lb5" value="高质量封面增强&#xa;功能点：列表封面资源替换" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f59e0b;fontSize=14;" vertex="1" parent="lg1"><mxGeometry x="1210" y="70" width="250" height="84" as="geometry"/></mxCell>

